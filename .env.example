# Copy this file to `.env` and adjust the values for your environment.
# All variables are optional in development — the app ships with safe defaults.

# Deployment environment: "development" (default) or "production".
# In production the app refuses to start unless SECRET_KEY is overridden,
# so set both together when deploying.
APP_ENV=development

# Database — PostgreSQL (this default matches the docker-compose "db" service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sdiary
SQLALCHEMY_ECHO=false

# JWT authentication — MUST be overridden with a random value in production
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Send the session cookie only over HTTPS — enable in production.
COOKIE_SECURE=false

# Redis cache
REDIS_HOST=localhost
REDIS_PORT=6379

# Outgoing mail (SMTP)
MAIL_USERNAME=school_diary@example.com
MAIL_PASSWORD=
MAIL_FROM=school_diary@example.com
MAIL_PORT=465
MAIL_SERVER=smtp.example.com
MAIL_FROM_NAME=School diary app
